---
import type { Meta } from '../types';
import ContactReveal from './ContactReveal.astro';

interface Props {
  meta: Meta;
}

const { meta } = Astro.props;

const [firstName, ...rest] = meta.name.split(' ');
const displayName = meta.preferredName
  ? `${firstName} (${meta.preferredName}) ${rest.join(' ')}`
  : meta.name;

// Encode at build time - plain text never reaches the static HTML.
const encodedEmail = Buffer.from(meta.contact.email).toString('base64');
const encodedPhone = Buffer.from(meta.contact.phone).toString('base64');

const platformIcons: Record<string, string> = {
  GitHub:   '/icons/github.svg',
  LinkedIn: '/icons/linkedin.svg',
};
---

<header class="contact-header">

  <div class="name-row">
    {meta.photo && (
      <img src={meta.photo} alt={meta.name} class="profile-photo" />
    )}
    <div class="name-text">
      <h1 class="name">{displayName}</h1>
      <p class="title">{meta.title}</p>
    </div>
  </div>

  <div class="contact-fields">
    <div class="contact-field">
      <img src="/icons/email.svg" alt="" class="field-icon" aria-hidden="true" />
      <ContactReveal encoded={encodedEmail} label="email" />
    </div>
    <div class="contact-field">
      <img src="/icons/phone.svg" alt="" class="field-icon" aria-hidden="true" />
      <ContactReveal encoded={encodedPhone} label="phone" />
    </div>
  </div>

  <ul class="social-links">
    {meta.resumeUrl && (
      <li>
        <a
          href={meta.resumeUrl}
          class="social-link resume-link"
          download
          aria-label="Download resume"
        >download resume</a>
      </li>
    )}
    {meta.social.map(({ url, label, platform }) => (
      <li>
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label={`${label} on ${platform}`}
        >
          {platformIcons[platform] && (
            <img src={platformIcons[platform]} alt="" class="social-icon" aria-hidden="true" />
          )}
        </a>
      </li>
    ))}
  </ul>

</header>

<style>
  .contact-header {
    padding-top: 2rem;
  }

  .name-row {
    display: flex;
    align-items: flex-end;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .name-text {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .profile-photo {
    width: 256px;
    height: 256px;
    object-fit: cover;
    object-position: center top;
    border-radius: 8px;
    flex-shrink: 0;
    border: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .profile-photo {
      max-width: 33.333%;
      height: auto;
    }
  }

  .name {
    font-family: var(--font-mono);
    font-size: clamp(1.333rem, 3.333vw, 2.333rem);
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .title {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  /* ── Contact fields ──────────────────────────────────────────────────────── */

  .contact-fields {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .contact-field {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
  }

  .field-icon {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    filter: invert(55%);
  }

  /* ── Social links ────────────────────────────────────────────────────────── */

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    height: 2.25rem;
    padding: 0 0.6em;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    transition:
      background-color var(--duration-fast) var(--ease-default),
      color            var(--duration-fast) var(--ease-default),
      border-color     var(--duration-fast) var(--ease-default);
  }

  .social-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .resume-link {
    padding: 0 0.75em;
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .resume-link:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  .social-icon {
    width: 1.25rem;
    height: 1.25rem;
    filter: invert(1);
    opacity: 0.6;
    transition: opacity var(--duration-fast) var(--ease-default);
  }

  .social-link:hover .social-icon {
    opacity: 1;
    filter: invert(73%) sepia(55%) saturate(500%) hue-rotate(118deg) brightness(103%);
  }
</style>
