---
import type { ShowcaseItem } from '../types';
import { inlineCode } from '../lib/utils';

interface Props {
  item: ShowcaseItem;
  globalIndex: number;
}

const { item, globalIndex } = Astro.props;

const hasScreenshots = item.screenshots.length > 0;
const hasCarousel = item.screenshots.length > 2;
---

<article
  class:list={[
    'showcase-item',
    hasScreenshots && 'has-screenshot',
  ]}
>
  <div class="text-col">
    <div class="item-header">
      <h3 class="item-name">{item.name}</h3>
      {item.tags && item.tags.length > 0 && (
        <div class="item-tags">
          {item.tags.map(tag => <span class="item-tag">{tag}</span>)}
        </div>
      )}
    </div>
    {item.bullets && item.bullets.length > 0 ? (
      <ul class="item-bullets">
        {item.bullets.map(b => <li set:html={inlineCode(b)} />)}
      </ul>
    ) : (
      <p class="item-desc">{item.description}</p>
    )}
    {item.links && item.links.length > 0 && (
      <div class="item-links">
        {item.links.map(link => (
          <a href={link.url} class="item-link" target="_blank" rel="noopener noreferrer">
            <svg class="item-link-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
            {link.url.replace(/^https?:\/\//, '')}
          </a>
        ))}
      </div>
    )}
  </div>

  {hasScreenshots && (
    <div class="screenshot-col">
      {hasCarousel && (
        <button class="sc-btn sc-prev" aria-label="Previous screenshots">&#8249;</button>
      )}
      <div class="sc-track">
        {item.screenshots.map((src, i) => (
          <img
            src={src}
            alt={`${item.name} screenshot ${i + 1}`}
            class="screenshot"
            data-sc-idx={i}
            hidden={hasCarousel && i >= 2}
            loading="lazy"
          />
        ))}
      </div>
      {hasCarousel && (
        <button class="sc-btn sc-next" aria-label="Next screenshots">&#8250;</button>
      )}
    </div>
  )}
</article>

<style>
  .showcase-item {
    display: grid;
    gap: 2rem;
    margin-bottom: 3.5rem;
  }

  /* Single column when no screenshots */
  .showcase-item:not(.has-screenshot) {
    grid-template-columns: 1fr;
  }

  /* Two-column layout on desktop when screenshots exist - text left, screenshot right */
  @media (min-width: 1024px) {
    .showcase-item.has-screenshot {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }


  }

  /* ── Screenshot ──────────────────────────────────────────────────────────── */

  .screenshot-col {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sc-track {
    display: flex;
    gap: 0.75rem;
    flex: 1;
    justify-content: center;
    align-items: flex-start;
  }

  .screenshot {
    max-height: 380px;
    width: auto;
    max-width: 100%;
    display: block;
    object-fit: contain;
    flex: 1;
    min-width: 0;
  }

  /* ── Carousel buttons ────────────────────────────────────────────────────── */

  .sc-btn {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-accent);
    background: none;
    border: 1px solid var(--color-border);
    padding: 0.3em 0.4em;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.15s ease;
  }

  .sc-btn:hover:not(:disabled) {
    border-color: var(--color-accent);
  }

  .sc-btn:disabled {
    opacity: 0.2;
    cursor: default;
  }

  /* ── Text ────────────────────────────────────────────────────────────────── */

  .item-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .item-name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1.3;
    margin-bottom: 0;
  }

  .item-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-self: center;
  }

  .item-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    padding: 0.15em 0.5em;
    letter-spacing: 0.04em;
  }

  .item-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    line-height: 1.75;
    max-width: 60ch;
  }

  .item-bullets {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    line-height: 1.75;
    max-width: 60ch;
    padding-left: 1.25rem;
    margin: 0;
  }

  .item-bullets li {
    margin-bottom: 0.25rem;
    position: relative;
  }

  .item-bullets code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--color-accent);
  }

  .item-bullets li::before {
    content: '';
    position: absolute;
    left: -1.25rem;
    top: 0.6em;
    width: 0.4em;
    height: 0.4em;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  /* ── Links ───────────────────────────────────────────────────────────────── */

  .item-links {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-left: 1.25rem;
    margin-top: 0.75rem;
  }

  .item-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.15s ease;
    position: relative;
    display: block;
  }

  .item-link-icon {
    position: absolute;
    left: -1.25rem;
    width: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .item-link:hover {
    opacity: 1;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.screenshot-col').forEach(col => {
    const imgs = col.querySelectorAll<HTMLImageElement>('.screenshot');
    if (imgs.length <= 2) return;

    const prevBtn = col.querySelector<HTMLButtonElement>('.sc-prev')!;
    const nextBtn = col.querySelector<HTMLButtonElement>('.sc-next')!;
    const maxPage = Math.ceil(imgs.length / 2) - 1;
    let page = 0;

    function render() {
      imgs.forEach((img, i) => {
        img.hidden = i < page * 2 || i >= page * 2 + 2;
      });
      prevBtn.disabled = page === 0;
      nextBtn.disabled = page === maxPage;
    }

    prevBtn.addEventListener('click', () => { page--; render(); });
    nextBtn.addEventListener('click', () => { page++; render(); });

    render();
  });
</script>
