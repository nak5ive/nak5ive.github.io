---
import type { ShowcaseItem } from '../types';

interface Props {
  item: ShowcaseItem;
  globalIndex: number;
}

const { item, globalIndex } = Astro.props;

const hasScreenshots = item.screenshots.length > 0;
---

<article
  class:list={[
    'showcase-item',
    hasScreenshots && 'has-screenshot',
  ]}
>
  {hasScreenshots && (
    <div class="screenshot-col">
      <img
        src={item.screenshots[0]}
        alt={item.name}
        class="screenshot"
        loading="lazy"
      />
    </div>
  )}

  <div class="text-col">
    <h3 class="item-name">{item.name}</h3>
    {item.bullets && item.bullets.length > 0 ? (
      <ul class="item-bullets">
        {item.bullets.map(b => <li>{b}</li>)}
      </ul>
    ) : (
      <p class="item-desc">{item.description}</p>
    )}
    {item.links && item.links.length > 0 && (
      <div class="item-links">
        {item.links.map(link => (
          <a href={link.url} class="item-link" target="_blank" rel="noopener noreferrer">
            {link.label}
          </a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .showcase-item {
    display: grid;
    gap: 2rem;
    margin-bottom: 3.5rem;
  }

  /* Single column when no screenshots */
  .showcase-item:not(.has-screenshot) {
    grid-template-columns: 1fr;
  }

  /* Two-column layout on desktop when screenshots exist - text left, screenshot right */
  @media (min-width: 1024px) {
    .showcase-item.has-screenshot {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }

    .showcase-item.has-screenshot .screenshot-col { order: 2; }
    .showcase-item.has-screenshot .text-col       { order: 1; }
  }

  /* ── Screenshot ──────────────────────────────────────────────────────────── */

  .screenshot-col {
    display: flex;
    justify-content: flex-end;
  }

  .screenshot {
    max-height: 400px;
    width: auto;
    max-width: 100%;
    display: block;
  }

  /* ── Text ────────────────────────────────────────────────────────────────── */

  .item-name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .item-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    line-height: 1.75;
    max-width: 60ch;
  }

  .item-bullets {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    line-height: 1.75;
    max-width: 60ch;
    padding-left: 1.25rem;
    margin: 0;
  }

  .item-bullets li {
    margin-bottom: 0.25rem;
    position: relative;
  }

  .item-bullets li::before {
    content: '';
    position: absolute;
    left: -1.25rem;
    top: 0.6em;
    width: 0.4em;
    height: 0.4em;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  /* ── Links ───────────────────────────────────────────────────────────────── */

  .item-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.875rem;
  }

  .item-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    text-decoration: none;
    border: 1px solid var(--color-accent);
    padding: 0.2em 0.6em;
    opacity: 0.75;
    transition: opacity 0.15s ease;
  }

  .item-link:hover {
    opacity: 1;
  }
</style>
