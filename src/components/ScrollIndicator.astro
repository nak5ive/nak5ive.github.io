---
// ScrollIndicator.astro
// Fixed right-side scroll progress indicator.
// Hidden below lg breakpoint (1024px).
// Markers: one per company (logo or initial) + Projects + Skills.
// Thumb (« ▓ »): draggable, tracks scroll progress.

import type { Company } from '../types';
import { companyId } from '../lib/utils';

interface Props {
  experience: Company[];
  photo?: string;
  name?: string;
}

const { experience, photo, name } = Astro.props;

const markers = [
  ...experience.map(c => ({
    id:      companyId(c.company),
    label:   c.company,
    logo:    c.logo,
    initial: c.company[0],
  })),
  { id: 'projects', label: 'Projects', logo: null as string | null,         initial: 'P' },
  { id: 'skills',   label: 'Skills',   logo: '/icons/skills.svg' as string | null, initial: 'S' },
];
---

<aside class="scroll-indicator" id="scroll-indicator" aria-hidden="true">

  <div class="track">
    <div class="track-line"></div>

    {photo && (
      <button class="marker profile-marker" data-target="contact" title={name ?? 'Contact'}>
        <img src={photo} alt="" class="marker-img profile-img" />
      </button>
    )}

    <div class="markers">
      {markers.map(marker => (
        <button
          class="marker"
          data-target={marker.id}
          title={marker.label}
        >
          {marker.logo
            ? <img src={marker.logo} alt="" class="marker-img" />
            : <span class="marker-initial">{marker.initial}</span>
          }
        </button>
      ))}
    </div>

    <div class="thumb" id="scroll-thumb">
      <span class="thumb-caret">&lsaquo;</span>
      <span class="thumb-caret">&rsaquo;</span>
    </div>
  </div>

</aside>

<style>
  /* Hidden on mobile - shown only at lg+ */
  .scroll-indicator {
    display: none;
  }

  @media (min-width: 1024px) {
    .scroll-indicator {
      display: flex;
      position: fixed;
      right: 1.25rem;
      top: 50%;
      transform: translateY(-50%);
      height: 50vh;
      width: 5rem;
      align-items: center;
      justify-content: center;
    }
  }

  /* ── Track ───────────────────────────────────────────────────────────────── */

  .track {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    width: 100%;
  }

  .track-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    background-color: var(--color-border);
  }

  /* ── Markers ─────────────────────────────────────────────────────────────── */

  .markers {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1;
  }

  .marker {
    position: absolute;
    left: 50%;
    transform: translateX(-50%) translateY(-50%);
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
    padding: 3px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.4;
    transition:
      opacity      var(--duration-fast) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default),
      box-shadow   var(--duration-fast) var(--ease-default);
    overflow: hidden;
  }

  .marker:hover {
    opacity: 0.7;
  }

  .marker.active {
    opacity: 1;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 2px var(--color-accent);
  }

  .marker-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 3px;
  }

  /* ── Profile marker ──────────────────────────────────────────────────────── */

  .profile-marker {
    position: absolute;
    left: 50%;
    top: -2.5rem;
    transform: translateX(-50%);
    width: 36px;
    height: 36px;
    border-radius: 6px;
    padding: 2px;
    z-index: 2;
  }

  .profile-img {
    object-fit: cover;
    object-position: center top;
    border-radius: 4px;
  }

  .marker-initial {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    line-height: 1;
    pointer-events: none;
  }

  .marker.active .marker-initial {
    color: var(--color-accent);
  }

  /* ── Thumb ───────────────────────────────────────────────────────────────── */

  .thumb {
    position: absolute;
    left: 0;
    right: 0;
    top: 0; /* set by JS */
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2px;
    cursor: grab;
    user-select: none;
    pointer-events: auto;
  }

  .thumb:active {
    cursor: grabbing;
  }

  .thumb-caret {
    font-family: var(--font-mono);
    font-size: 1.375rem;
    color: var(--color-accent);
    line-height: 1;
  }
</style>

<script>
  const indicator     = document.getElementById('scroll-indicator') as HTMLElement;
  const thumb         = document.getElementById('scroll-thumb') as HTMLElement;
  const profileMarker = document.querySelector<HTMLElement>('.profile-marker');

  if (!indicator || !thumb) throw new Error('ScrollIndicator: elements not found');

  // ── Filter markers to only those with a section present in the DOM ─────────
  // Profile marker is excluded from positionMarkers - its CSS top: -2.5rem
  // keeps it anchored above the track; it participates in active/click logic only.
  const markers = [...document.querySelectorAll<HTMLElement>('.marker:not(.profile-marker)')].filter(m => {
    const exists = !!document.getElementById(m.dataset.target!);
    if (!exists) m.style.display = 'none';
    return exists;
  });

  // ── Proportional marker placement ─────────────────────────────────────────
  // After proportional placement, enforce a minimum gap so markers never
  // overlap regardless of how close their sections are on the page.

  const MARKER_MIN_GAP = 32; // px - marker height (28px) + 4px breathing room

  function enforceMinSpacing(): void {
    const trackH = indicator.offsetHeight;
    // markers are already sorted top-to-bottom by section order
    // Forward pass: push markers down if too close
    for (let i = 1; i < markers.length; i++) {
      const prev = parseFloat(markers[i - 1].style.top);
      const min  = prev + MARKER_MIN_GAP;
      if (parseFloat(markers[i].style.top) < min) {
        markers[i].style.top = `${min}px`;
      }
    }
    // If the last marker was pushed past the track bottom, pull everything up
    const last = markers[markers.length - 1];
    if (last) {
      const overflow = parseFloat(last.style.top) - trackH;
      if (overflow > 0) {
        markers.forEach(m => {
          m.style.top = `${parseFloat(m.style.top) - overflow}px`;
        });
      }
    }
  }

  function positionMarkers(): void {
    const scrollable = document.documentElement.scrollHeight - window.innerHeight;
    if (scrollable <= 0) return;
    const trackH = indicator.offsetHeight;
    markers.forEach(marker => {
      const section = document.getElementById(marker.dataset.target!);
      if (!section) return;
      const ratio = Math.min(section.offsetTop / scrollable, 1);
      marker.style.top = `${ratio * trackH}px`;
    });
    enforceMinSpacing();
  }

  // ── Thumb position ────────────────────────────────────────────────────────
  // Maps scrollY [0, scrollable] → top [0, trackH - thumbH] so the thumb
  // travels the full length of the track.

  function updateThumb(): void {
    const scrollable = document.documentElement.scrollHeight - window.innerHeight;
    if (scrollable <= 0) return;
    const progress    = Math.min(window.scrollY / scrollable, 1);
    const trackH      = indicator.offsetHeight;
    // Start the thumb at the profile marker's center (above the track when at top),
    // and travel to the bottom of the track at full scroll.
    const startTop    = profileMarker
      ? profileMarker.offsetTop + profileMarker.offsetHeight / 2
      : 0;
    thumb.style.top = `${startTop + progress * (trackH - startTop)}px`;
  }

  function update(): void { positionMarkers(); updateThumb(); }

  function setActiveMarker(id: string): void {
    markers.forEach(m => m.classList.toggle('active', m.dataset.target === id));
    if (profileMarker) {
      profileMarker.classList.toggle('active', profileMarker.dataset.target === id);
    }
  }

  function checkBottomActive(): void {
    const scrollable = document.documentElement.scrollHeight - window.innerHeight;
    if (scrollable <= 0) return;
    if (window.scrollY >= scrollable - 2) {
      const last = markers[markers.length - 1];
      if (last) setActiveMarker(last.dataset.target!);
    }
  }

  window.addEventListener('scroll', () => { updateThumb(); checkBottomActive(); }, { passive: true });
  window.addEventListener('resize', update, { passive: true });
  update();

  // ── Marker clicks → smooth scroll ────────────────────────────────────────

  document.querySelectorAll<HTMLElement>('[data-target]').forEach(marker => {
    marker.addEventListener('click', () => {
      const target = document.getElementById(marker.dataset.target!);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // ── IntersectionObserver → active marker ─────────────────────────────────

  const io = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      setActiveMarker(entry.target.id);
    });
  }, { rootMargin: '-40% 0px -60% 0px', threshold: 0 });

  markers.forEach(marker => {
    const el = document.getElementById(marker.dataset.target!);
    if (el) io.observe(el);
  });
  if (profileMarker) {
    const el = document.getElementById(profileMarker.dataset.target!);
    if (el) io.observe(el);
  }

  // ── Drag thumb → scroll page ──────────────────────────────────────────────

  let dragging    = false;
  let dragStartY  = 0;
  let dragStartSY = 0;

  function startDrag(y: number): void {
    dragging    = true;
    dragStartY  = y;
    dragStartSY = window.scrollY;
  }

  function moveDrag(y: number): void {
    if (!dragging) return;
    const dy         = y - dragStartY;
    const scrollable = document.documentElement.scrollHeight - window.innerHeight;
    window.scrollTo(0, dragStartSY + (dy / indicator.offsetHeight) * scrollable);
  }

  function endDrag(): void { dragging = false; }

  // Mouse
  thumb.addEventListener('mousedown', e => { startDrag(e.clientY); e.preventDefault(); });
  window.addEventListener('mousemove', e => moveDrag(e.clientY));
  window.addEventListener('mouseup', endDrag);

  // Touch
  thumb.addEventListener('touchstart', e => { startDrag(e.touches[0].clientY); }, { passive: true });
  window.addEventListener('touchmove',  e => { if (dragging) moveDrag(e.touches[0].clientY); }, { passive: true });
  window.addEventListener('touchend', endDrag);
</script>
